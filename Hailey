
local USER_ID = 1994741804

local Players       = game:GetService("Players")
local RunService    = game:GetService("RunService")

local local_player  = Players.LocalPlayer
local character     = local_player.Character or local_player.CharacterAdded:Wait()
local humanoid      = character:WaitForChild("Humanoid")

local last_description  = nil
local scale_connection  = nil
local char_connection   = nil

local function get_part(name)
    return character:FindFirstChild(name)
end

local function safe_destroy(obj)
    if obj and obj.Parent then
        obj:Destroy()
    end
end

local function disconnect(conn)
    if conn then
        conn:Disconnect()
    end
end

local function apply_description(description, is_reapply)
    humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    if description and not is_reapply then
        safe_destroy(last_description)
        last_description = description
    end

    local desc = description or last_description
    if not desc then return end

    desc.BodyTypeScale    = humanoid.BodyTypeScale.Value
    desc.HeadScale        = humanoid.HeadScale.Value
    desc.DepthScale       = humanoid.BodyDepthScale.Value
    desc.HeightScale      = humanoid.BodyHeightScale.Value
    desc.ProportionScale  = humanoid.BodyProportionScale.Value
    desc.WidthScale       = humanoid.BodyWidthScale.Value

    local current_desc = humanoid:GetAppliedDescription()
    if current_desc then
        desc:SetEmotes(current_desc:GetEmotes())
    end

    humanoid:RemoveAccessories()
    safe_destroy(character:FindFirstChildOfClass("Shirt"))
    safe_destroy(character:FindFirstChildOfClass("Pants"))
    safe_destroy(character:FindFirstChildOfClass("ShirtGraphic"))

    humanoid:ApplyDescriptionClientServer(desc)

    if not is_reapply then
        disconnect(scale_connection)
        scale_connection = humanoid.BodyWidthScale:GetPropertyChangedSignal("Value"):Connect(function()
            task.wait()
            if last_description then
                last_description.BodyTypeScale    = humanoid.BodyTypeScale.Value
                last_description.HeadScale        = humanoid.HeadScale.Value
                last_description.DepthScale       = humanoid.BodyDepthScale.Value
                last_description.HeightScale      = humanoid.BodyHeightScale.Value
                last_description.ProportionScale  = humanoid.BodyProportionScale.Value
                last_description.WidthScale       = humanoid.BodyWidthScale.Value
                humanoid:ApplyDescriptionClientServer(last_description)
            end
            disconnect(scale_connection)
            scale_connection = nil
        end)
    end
end

local function on_character_added(new_char)
    character = new_char
    humanoid  = new_char:WaitForChild("Humanoid")
    wait(0.15) 
    apply_description(last_description, true)
end

char_connection = local_player.CharacterAdded:Connect(on_character_added)


local function load_user(user_id)
    local ok, desc = pcall(function()
        return Players:GetHumanoidDescriptionFromUserId(user_id)
    end)
    if ok and desc then
        apply_description(desc, false)
    else
        
    end
end

if USER_ID and USER_ID ~= 0 then
    load_user(USER_ID)
else
   
end
